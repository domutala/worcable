# ========================================================
# Server Configuration
# ========================================================

# Port the application should listen on
PORT=4730

# Public URL of the application (used for redirects and absolute links)
# Local example: https://app.worcable.com
NUXT_PUBLIC_APP_URL="<APP URL>"

# ========================================================
# Database (MongoDB)
# ========================================================

# Connection URL for your MongoDB database
# Local format: mongodb://localhost:27017/database_name
# Atlas format: mongodb+srv://username:password@cluster.abcd.mongodb.net/database_name
NUXT_DATABASE_URL="<DATABASE URL>"

# ========================================================
# Security
# ========================================================

# Secret key used to sign cookies or encrypt sessions
# Must be a long, random string (generated via: openssl rand -base64 60)
# Example: qygjsR9Df5D3KMODH7VwwjNJ1vgFI2psH7pOgrtt2KydC65U1TwBED0BqYYH
NUXT_SECRET_KEY="<APP SECRET KEY>"